rules_version = '2';

// Igual que el CRM hermano (Legendar-IA): no se usa Firebase Auth, así que
// Firestore no tiene forma de saber quién hace cada lectura/escritura
// (request.auth siempre es null). El control de acceso vive en la sesión
// propia (cookie JWT firmada en /api/session) y en qué botones/páginas
// muestra la UI según el rol — no a nivel de base de datos. Es aceptable
// para una herramienta interna de equipo, no para datos públicos.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
