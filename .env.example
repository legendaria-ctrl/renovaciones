# Firebase (Console > Configuración del proyecto > Tus apps > SDK setup)
# Solo se usa Firestore, no Firebase Auth: el login es propio (ver más abajo).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Google Sheet de origen (debe estar compartido como "cualquiera con el enlace puede ver")
SHEET_ID=
SHEET_GID=0

# Sesión propia (login con nombre + clave compartida por rol, sin Firebase Auth)
SESSION_SECRET=
ADMIN_PASSCODE=
COORDINADOR_PASSCODE=
VENDEDOR_PASSCODE=
